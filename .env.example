# Database Configuration
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=one_estela_place
DB_PORT=3306

# Application URL
NEXT_PUBLIC_API_URL=http://localhost:3000

# Email Configuration (Optional - Leave empty for development mode)
# For Gmail: Use App Password from https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Development Mode: If SMTP is not configured, verification codes will be shown in console
NODE_ENV=development